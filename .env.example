# Firebase Configuration (not needed for local demo mode)
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Google Places API (for address autocomplete)
# Get a key at https://console.cloud.google.com/apis/credentials
# Enable the "Places API" service
VITE_GOOGLE_PLACES_API_KEY=

# NYC GeoClient API (for auto-populating BBL/BIN from address)
# Register at https://api-portal.nyc.gov/
VITE_NYC_GEOCLIENT_APP_ID=
VITE_NYC_GEOCLIENT_APP_KEY=
